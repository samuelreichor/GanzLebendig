{
  "require": {
    "craftcms/ckeditor": "^5.5.0",
    "craftcms/cms": "^5.10.1",
    "doublesecretagency/craft-cpcss": "^3.0.0",
    "nystudio107/craft-emptycoalesce": "^5.0.0",
    "nystudio107/craft-templatecomments": "^5.0.4",
    "nystudio107/craft-vite": "^5.0.1",
    "samuelreichor/craft-insights": "^1.4.0",
    "samuelreichor/craft-quick-edit": "^5.3.1",
    "studioespresso/craft-dumper": "^5.0.1",
    "vaersaagod/seomate": "^3.3.0",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.1.0",
    "nystudio107/craft-autocomplete": "^1.12.1",
    "roave/security-advisories": "dev-latest",
    "yiisoft/yii2-shell": "^2.0.5"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.4"
    },
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "cweagans/composer-patches": true,
      "yiisoft/yii2-composer": true,
      "php-http/discovery": true
    }
  },
  "scripts": {
    "craft-update": [
      "@pre-craft-update",
      "@post-craft-update"
    ],
    "create-folders": [
      "mkdir -p ./storage",
      "mkdir -p ./config/project",
      "mkdir -p ./web/cpresources",
      "mkdir -p ./web/assets"
    ],
    "pre-craft-update": [
      "@create-folders"
    ],
    "post-craft-update": [
      "@php craft install/check && php craft clear-caches/compiled-templates || exit 0",
      "@php craft install/check && php craft clear-caches/data || exit 0",
      "@php craft install/check && php craft clear-caches/temp-files || exit 0",
      "@php craft install/check && php craft up || exit 0"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "pre-update-cmd": "@pre-craft-update",
    "pre-install-cmd": "@pre-craft-update",
    "post-update-cmd": "@post-craft-update",
    "post-install-cmd": "@post-craft-update"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
