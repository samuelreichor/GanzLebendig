{% block htmlPage %}
  <!DOCTYPE html>
  <html lang="{{ craft.app.language |slice(0,2) }}">
  <head>
    {% block head %}
      <meta charset="utf-8">
      <meta name="viewport" content="initial-scale=1,minimum-scale=1,width=device-width,viewport-fit=cover">
      {% hook 'seomateMeta' %}
      {{ include('_layouts/_partials/fonts.twig') }}
      {{ include('_layouts/_partials/favicon.twig') }}
    {% endblock %}
  </head>

  <body>
  {% cache %}
    {% block body %}
    {% endblock %}
  {% endcache %}

  {{ craft.vite.script("assets/js/app.ts", false) }}
  {{ craft.insights.trackingScript() }}
  </body>
  </html>
{% endblock %}
