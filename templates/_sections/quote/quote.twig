{# >>> Comp Settings #}
{% set compDefaults = {
  data: {
    name: 's-quote',
    quote: '',
    author: '',
    bgImage: null,
  },
  classes: {
    root: 'outside-container m-top-md',
    custom: '',
    panel: 'relative overflow-hidden rounded-lg px-ds-8 py-ds-16 md:px-ds-16 md:py-ds-24 text-center',
    overlay: 'absolute inset-0 z-10 bg-gradient-to-t from-ink-900/60 via-ink-900/45 to-ink-900/45',
    content: 'relative z-20 mx-auto max-w-3xl flex flex-col items-center gap-ds-8',
    mark: 'size-16',
    blockquote: 'text-5xl font-semibold text-balance',
    author: 'text-lg not-italic',
  },
} %}

{# >>> Merge data / classes #}
{% set props = {
  data: data is defined and data is iterable ? compDefaults.data | merge(data) : compDefaults.data,
  classes: classes is defined and classes is iterable ? compDefaults.classes | merge(classes) : compDefaults.classes,
} %}

{% if props.data.quote %}
  {% set hasImage = props.data.bgImage is not empty %}
  {% set panelTone = hasImage ? 'text-cream-50 drop-shadow-md' : 'bg-cream-100 text-ink-900' %}
  {% set markTone = hasImage ? 'text-cream-50/60' : 'text-sage-400' %}
  {% set authorTone = hasImage ? 'text-cream-50' : 'text-ink-500' %}

  <div class="{{ props.data.name }} {{ props.classes.root }} {{ props.classes.custom }}">
    <figure class="{{ props.classes.panel }} {{ panelTone }}">
      {% if hasImage %}
        {{ include('_components/image/image.twig', {
          data: {
            image: props.data.bgImage,
            objectFit: 'cover',
            transform: 'landscape',
            sizes: '100vw',
          },
          classes: {
            custom: 'absolute inset-0',
          }
        }, with_context = false) }}
        <div class="{{ props.classes.overlay }}"></div>
      {% endif %}

      <div class="{{ props.classes.content }}">
        <svg class="{{ props.classes.mark }} {{ markTone }}" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
          <path d="M0 0h24v24H0z" fill="none" />
          <path fill="currentColor" d="M11.192 15.757q0-1.32-.69-2.217q-.489-.618-1.327-.812c-.55-.128-1.07-.137-1.54-.028c-.16-.95.1-1.956.76-3.022q.992-1.598 2.558-2.403L9.372 5c-.8.396-1.56.898-2.26 1.505c-.71.607-1.34 1.305-1.9 2.094s-.98 1.68-1.25 2.69s-.345 2.04-.216 3.1c.168 1.4.62 2.52 1.356 3.35Q6.205 19 7.85 19c.965 0 1.766-.29 2.4-.878q.941-.864.94-2.368zm9.124 0q0-1.32-.69-2.217q-.49-.63-1.327-.817q-.84-.185-1.54-.022c-.16-.94.09-1.95.752-3.02q.99-1.59 2.556-2.4L18.49 5q-1.201.594-2.26 1.505a11.3 11.3 0 0 0-1.894 2.094c-.556.79-.97 1.68-1.24 2.69a8 8 0 0 0-.217 3.1c.166 1.4.616 2.52 1.35 3.35q1.1 1.252 2.743 1.252q1.45.002 2.402-.877q.941-.864.942-2.368z" />
        </svg>
        <blockquote class="{{ props.classes.blockquote }}">
          {{ props.data.quote|nl2br }}
        </blockquote>

        {% if props.data.author %}
          <figcaption class="{{ props.classes.author }} {{ authorTone }}">
            &mdash;&nbsp;{{ props.data.author }}
          </figcaption>
        {% endif %}
      </div>
    </figure>
  </div>
{% endif %}
