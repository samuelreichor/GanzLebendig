{# >>> Comp Settings #}
{% set compDefaults = {
  data: {
    name: 's-hero',
    image: null,
    headline: '',
    text: '',
    link: null,
  },
  classes: {
    root: 'w-full flex items-center',
    custom: '',
    bgWrap: 'js-hero-bg absolute inset-0 z-0',
    overlay: 'absolute inset-0 z-10 bg-gradient-to-b from-ink-900/40 via-ink-900/45 to-ink-900/70',
    overlayTop: 'absolute top-0 inset-x-0 h-[calc(var(--navigation-height)+1rem)] z-10 bg-gradient-to-b from-ink-900/65 to-transparent pointer-events-none',
    content: 'relative z-20 w-full outside-container text-center mt-[calc(var(--navigation-height)-1rem)]',
    contentInner: 'max-w-2xl mx-auto flex flex-col items-center gap-ds-6',
    linkWrapper: 'mt-ds-4',
  },
} %}

{# >>> Merge data / classes #}
{% set props = {
  data: data is defined and data is iterable ? compDefaults.data | merge(data) : compDefaults.data,
  classes: classes is defined and classes is iterable ? compDefaults.classes | merge(classes) : compDefaults.classes,
} %}

{% if props.data.headline %}
  <header class="{{ props.data.name }} {{ props.classes.root }} {{ props.classes.custom }} {{ props.data.image ? 'js-hero relative overflow-hidden' : 'relative bg-cream-50' }}">
    {% if props.data.image %}
      <div class="{{ props.classes.bgWrap }}">
        {{ include('_components/image/image.twig', {
          data: {
            image: props.data.image,
            objectFit: 'cover',
            transform: 'landscape',
            sizes: '100vw',
            lazy: false,
          },
          classes: {
            custom: '',
          }
        }, with_context = false) }}
      </div>
      <div class="{{ props.classes.overlay }}"></div>
      <div class="{{ props.classes.overlayTop }}"></div>
    {% endif %}

    <div class="{{ props.classes.content }} {{ props.data.image ? 'py-20 md:py-40' : 'py-ds-32' }}">
      <div class="{{ props.classes.contentInner }}">
        {{ include('_components/headline/headline.twig', {
          data: {
            text: props.data.headline,
            variantSize: 'h1',
            tag: 'h1',
          },
          classes: {
            custom: props.data.image ? 'mx-auto !text-cream-50 drop-shadow-lg' : 'mx-auto !text-ink-900',
          }
        }, with_context = false) }}

        {% if props.data.text %}
          {{ include('_components/text/text.twig', {
            data: {
              text: props.data.text,
              raw: true,
              size: 'xl',
              alignment: 'center',
            },
            classes: {
              custom: props.data.image ? 'mx-auto text-cream-50/95 drop-shadow-lg' : 'mx-auto text-ink-700',
            }
          }, with_context = false) }}
        {% endif %}

        {% if props.data.link %}
          <div class="{{ props.classes.linkWrapper }}">
            {{ include('_components/linkButton/linkButton.twig', {
              data: {
                link: props.data.link,
                align: 'center',
                linkStyle: props.data.image ? 'secondary' : 'primary',
              },
            }, with_context = false) }}
          </div>
        {% endif %}
      </div>
    </div>
  </header>
{% endif %}
