{#
Image Helper
------------------------------------------------------------

{% import '_macros/_macro-imageHelper.twig' as image  %}
#}

{% apply spaceless %}
  {# Get Image Extension #}
  {%- macro getImageExtension(image) -%}
    {%- if image ??? null -%}
      {%- if image is iterable -%}
        {{- image.extension | lower -}}
      {%- else -%}
        {{- image | split('.') | last | lower -}}
      {%- endif -%}
    {%- endif -%}
  {%- endmacro -%}


  {# Get Image Extension #}
  {%- macro isTransformable(image) -%}
    {%- set skipTransformsForThisExtensions = ['gif', 'tiff', 'svg'] -%}
    {%- set extension = _self.getImageExtension(image) -%}
    {%- if extension not in skipTransformsForThisExtensions -%}
      {{- true -}}
    {%- else -%}
      {{- false -}}
    {%- endif -%}
  {%- endmacro -%}


  {# Render Image #}
  {%- macro renderImage(image, placeholder, lazy = true, objectFit = null) -%}
    {%- if image ??? null -%}
      {%- set focalpoint = image.getFocalpoint('asCss') -%}
      {%- set imageUrl = image.getUrl() -%}
      <img class="{{ lazy ? 'lazyload w-full' : '' }}"
          {%- if objectFit -%}
            style="object-fit: {{ objectFit }}; object-position: {{ focalpoint | default('50% 50%') }}; width: 100%; height:100%"
          {%- endif -%}
          {%- if lazy -%}
            src="{{- placeholder -}}"
            data-sizes="auto"
            data-src="{{- imageUrl -}}"
          {%- else -%}
            src="{{- imageUrl -}}"
          {%- endif -%}
           alt="{{- image.alt ?? '' -}}"
           width="{{- image.width -}}"
           height="{{- image.height -}}"/>
    {%- endif -%}
  {%- endmacro -%}


  {# Render NoScript #}
  {%- macro renderNoScript(image) -%}
    {%- if image ??? null -%}
      <noscript><img src="{{ image.getUrl() }}" alt="{{ image.alt ?? '' }}"/></noscript>
    {%- endif -%}
  {%- endmacro -%}


  {# Render Source #}
  {%- macro renderSource(image, transform, transformedImages = null, lazy = true, mediaQuery) -%}
    {%- if image ??? null -%}
      {%- set transform = transform | default('landscape') -%}

      {%- if craft.imager.serverSupportsWebp() -%}
        {% if lazy %}
          <source data-srcset="{{ _self.getSrcset(image, transform, null, 'webp') }}"
                  media="{{- mediaQuery -}}"
                  type="image/webp">
        {% else %}
          <source media="{{- mediaQuery -}}"
                  sizes="100vw"
                  srcset="{{ _self.getSrcset(image, transform, null, 'webp') }}"
                  type="image/webp">
        {%- endif -%}
      {%- endif -%}

      {% if lazy %}
        <source data-srcset="{{- _self.getSrcset(image, transform, transformedImages) -}}"
                media="{{- mediaQuery -}}">
      {% else %}
        <source media="{{- mediaQuery -}}"
                sizes="100vw"
                srcset="{{- _self.getSrcset(image, transform, transformedImages) -}}">
      {%- endif -%}
    {%- endif -%}
  {%- endmacro -%}


  {# Get srcset #}
  {%- macro getSrcset(image, transform, transformedImages = null, format = null) -%}
    {%- if image ??? null -%}
      {%- set transform = transform | default('landscape') -%}
      {%- set transformable = _self.isTransformable(image) -%}
      {%- if transformable == 'true' and transformedImages -%}
        {{- craft.imager.srcset(transformedImages) | trim -}}
      {%- elseif transformable -%}
        {{- craft.imager.srcset(craft.imager.transformImage(image, transform, { format: format })) | trim -}}
      {%- else -%}
        {{- image.url -}}
      {%- endif -%}
    {%- endif -%}
  {%- endmacro -%}


  {# Get Dominant Color #}
  {%- macro getDominantColor(image, dominantColor = null) -%}

    {%- set finalColor = 'transparent' -%}

    {%- if not (dominantColor == 'transparent') and not dominantColor is same as(false) -%}
      {%- if craft.app.config.general.custom.dominantColor ??? null -%}
        {%- set finalColor = craft.app.config.general.custom.dominantColor -%}
      {%- elseif dominantColor starts with '#' -%}
        {%- set finalColor = dominantColor -%}
      {%- elseif not craft.app.config.general.custom.localDevPerformance ??? null and not (image.extension | lower == 'png') and _self.isTransformable(image) == 'true' -%}
        {# Create Mini Image for Dominant Color #}
        {%- set image = craft.imager.transformImage(image, 'dominantColor')|first -%}
        {%- set finalColor = craft.imager.getDominantColor(image) -%}
      {%- endif -%}
    {%- endif -%}

    {{- finalColor -}}
  {%- endmacro -%}


  {# Get Placeholder #}
  {%- macro getPlaceHolder(image, width, height, dominantColor = null) -%}
    {% if image ??? null %}
      {{- craft.imager.placeholder({
        color: _self.getDominantColor(image, dominantColor),
        width: width,
        height: height
      }) -}}
    {%- endif -%}
  {%- endmacro -%}
{%- endapply -%}
