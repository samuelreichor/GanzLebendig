{% set props = defineProps(_context,
  component='gridOverlay',
  data={
    optional: {
      cols: 12,
    }
  },
  classes={
    root: '',
    btn: 'fixed bottom-14 right-4 js-gridOverlayBtn z-grid',
    wrapper: 'js-gridOverlay hidden fixed top-0 left-0 right-0 h-screen border-2',
    container: 'container h-full',
    column: 'col-span-1 border-l last:border-r border-black/30 text-black/30 flex justify-center items-end',
  }
) %}

{% if props.data.cols %}
  <div class="{{ props.classes.root }}">
  <button class="{{ props.classes.btn }}">Grid</button>
    <div class="{{ props.classes.wrapper }}">
      <div class="{{ props.classes.container }}">
        {% for i in 1..props.data.cols %}
          <div class="{{ props.classes.column }}">{{ i }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}
