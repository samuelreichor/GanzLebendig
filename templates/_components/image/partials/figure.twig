{# >>> Comp Settings #}
{% set props = defineProps(_context,
  component='figure',
  data={
    image: {
      type: 'asset',
      about: 'A Craft image asset'
    },
    optional: {
      showCaption: false,
      dominantColor: false,
      lazy: true,
      transform: 'auto',
      objectFit: '',
    }
  },
  classes={
    root: '',
  }
) %}

<figure class="{{ props.classes.root }}">
  {# ---- image ---- #}
  {{ include('_components/image/partials/image.twig', {
    data: {
      image: props.data.image,
      dominantColor: props.data.dominantColor,
      lazy: props.data.lazy,
      transform: props.data.transform,
      objectFit: props.data.objectFit,
    }
  }, with_context = false) }}

  {# ---- caption ---- #}
  {{ include('_components/caption/caption.twig', {
    data: {
      text: props.data.image.caption,
    }
  }, with_context = false) }}
</figure>
