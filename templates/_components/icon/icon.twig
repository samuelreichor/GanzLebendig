{# >>> Comp Settings #}
{% set props = defineProps(_context,
  component='icon',
  data={
    name: {
      type: 'string',
      about: 'The name of the icon without the .svg',
    },
    optional: {
      attributes: {
        about: 'There you can set attributes, in a key value pair',
        default: [],
      },
    }
  },
  variants={
    size: ['base', 'auto', 'small', 'xl'],
  },
  classes={
    root: 'inline-flex origin-center',
    size: {
      base:{
        root: 'w-6 h-6',
      },
      auto:{
        root: '',
      },
      small:{
        root: 'w-4 h-4',
      },
      xl:{
        root: 'w-12 h-12',
      },
    },
  }
) %}

{% if props.data.name %}
  {{ svg("@webroot/dist/images/svg/" ~ props.data.name ~ ".svg")|attr(props.data.attributes|merge({
    class: props.classes.root })) }}
{% endif %}
