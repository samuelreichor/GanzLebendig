{# >>> Comp Settings #}
{% set compDefaults = {
  data: {
    name: 'c-text',
    text: '',
    tag: 'div',
    theme: '',
    raw: false,
    size: 'large',
    alignment: 'left',
  },
  classes: {
    root: 'c-text--richText',
    custom: '',
  },
  variants: {
    size: {
      large: 'text-lg',
      base: 'text-base',
      xl: 'text-xl',
    },
    alignment: {
      left: 'text-left',
      center: 'text-center',
      right: 'text-right',
    }
  }
} %}

{# >>> Merge data / classes #}
{% set props = {
  data: data is defined and data is iterable ? compDefaults.data | merge(data) : compDefaults.data,
  classes: classes is defined and classes is iterable ? compDefaults.classes | merge(classes) : compDefaults.classes,
  variants: compDefaults.variants,
} %}

{% if props.data.text %}
  <{{ props.data.tag }} class="{{ props.data.name }} {{ props.classes.root }} {{ props.classes.custom }} {{ props.data.theme == "onBackground" ? props.classes.onBackground }} {{ props.variants.size[props.data.size] }} {{ props.variants.alignment[props.data.alignment] }}">
    {{ props.data.raw ? props.data.text | raw : props.data.text }}
  </{{ props.data.tag }}>
{% endif %}
